@model List<Product>

    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-secondary bg-gradient ml-0  py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="text-white py-2">Product List</h2>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6">
            </div>
            <div class="col-6 text-end">
                <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle-fill"></i> Create New Product
                </a>
            </div>
        </div>
        <table class="table table-hover table-bordered table-striped">
            <tr class="table-primary">
                <th scope="col"> Title</th>
                <th scope="col"> ISBN</th>
                <th scope="col"> Price</th>
                <th scope="col"> Author</th>
                <th scope="col">  Category</th>
                <th scope="col">Actions </th>
            </tr>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td scope="col">@product.Title</td>
                        <td scope="col">@product.ISBN</td>
                        <td scope="col">@product.ListPrice</td>
                        <td scope="col">@product.Author</td>
                        <td scope="col">Category</td>
                        <td>
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Product" asp-action="Edit" asp-route-productId="@product.Id" class="btn btn-primary mx-2">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-controller="Product" asp-action="Delete" asp-route-productid="@product.Id" class="btn btn-danger mx-2">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
<div class="container">
    
    </div>
   